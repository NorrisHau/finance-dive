---
import type { CollectionEntry } from "astro:content";
import { getPath } from "@/utils/getPath";
import Datetime from "./Datetime.astro";
import { getResolvedPostCover } from "@/utils/postCovers";

type Props = {
  variant?: "h2" | "h3";
  index?: number;
  lazy?: boolean;
} & CollectionEntry<"blog">;

const {
  variant: Heading = "h2",
  index = 0,
  lazy = false,
  id,
  data,
  filePath,
} = Astro.props as Props;

const { title, description, tags = [], ...props } = data;

const previewBase = description;
const previewText =
  previewBase.length > 108
    ? `${previewBase.slice(0, 108).trim()}...`
    : previewBase;

const domain = tags.includes("technology")
  ? "technology"
  : tags.includes("health")
    ? "health"
    : "investment";

const domainLabelMap = {
  investment: "投资",
  technology: "科技",
  health: "健康",
} as const;

const domainIconMap = {
  investment: "I",
  technology: "T",
  health: "H",
} as const;

const explicitCover =
  typeof data.ogImage === "string" ? data.ogImage : data.ogImage?.src;
const coverImage = getResolvedPostCover(id, explicitCover);
---

<li
  class="my-1"
  style={`--card-index:${index};`}
  data-home-card
  hidden={lazy ? true : undefined}
>
  <a
    href={getPath(id, filePath)}
    class:list={[
      "bento-card",
      "focus-visible:no-underline focus-visible:outline-2 focus-visible:outline-dashed",
    ]}
    style="animation-delay: calc(var(--card-index, 0) * 70ms);"
  >
    <div class="bento-card__content">
      <Heading class="bento-card__title text-foreground">
        {title}
      </Heading>
      <p class="bento-card__desc">{previewText}</p>
      <div class="bento-card__meta">
        <Datetime {...props} />
        <span class="domain-pill" data-domain={domain}>
          <span aria-hidden="true">{domainIconMap[domain]}</span>
          {domainLabelMap[domain]}
        </span>
      </div>
    </div>

    <div class="bento-card__thumb" aria-hidden="true">
      {
        coverImage ? (
          <img src={coverImage} alt="" loading="lazy" decoding="async" />
        ) : (
          <svg viewBox="0 0 320 220" role="img" aria-label="文章默认配图">
            <defs>
              <linearGradient id="thumbBg" x1="0" y1="0" x2="1" y2="1">
                <stop offset="0%" stop-color="#f7f2e7"></stop>
                <stop offset="100%" stop-color="#ece2ce"></stop>
              </linearGradient>
            </defs>
            <rect width="320" height="220" rx="18" fill="url(#thumbBg)" />
            <path d="M46 44v132M46 176h228" stroke="#b79e76" stroke-width="2" />
            <path
              d="M74 148 106 132 132 138 164 108 198 116 234 84 266 98"
              fill="none"
              stroke="#7f6540"
              stroke-width="4"
              stroke-linecap="round"
              stroke-linejoin="round"
            />
            <g stroke="#a88d66" stroke-width="2.6" stroke-linecap="round">
              <path d="M86 156v-24" />
              <path d="M110 150v-32" />
              <path d="M136 154v-18" />
              <path d="M162 128v-30" />
              <path d="M188 136v-26" />
              <path d="M214 114v-20" />
              <path d="M238 102v-30" />
            </g>
          </svg>
        )
      }
    </div>
  </a>
</li>
