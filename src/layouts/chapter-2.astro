---
// src/layouts/chapter-2.astro
// 第二章交互区：
// 1) 不可能三角（多资产同图 + 图例置顶）
// 2) 10 秒动画（量化执行 vs 散户观察）
// 3) 风险地图（常见度 vs 破坏性）
---

<section
  class="chapter-viz border-skin-line mt-4 space-y-4 border-t border-dashed pt-4"
>
  <div class="chart-card">
    <h3 class="mb-3 text-lg font-semibold">不可能三角：多资产同图对比</h3>
    <p class="mb-4 text-sm text-foreground/70">
      图例在图上方，颜色仅用于区分资产，不代表好坏。
    </p>
    <div class="triangle-legend" id="triangleLegend"></div>
    <canvas id="triangleChart"></canvas>
  </div>

  <div class="quant-scene" id="quantScene">
    <div class="quant-scene__head">
      <p class="quant-scene__title">10 秒执行动画：量化与散户的动作差距</p>
      <p class="quant-scene__subtitle" id="quantSceneCaption">
        第 0.0 秒：等待信号出现
      </p>
    </div>

    <div class="quant-axis">
      <span>0s</span>
      <span>2s</span>
      <span>4s</span>
      <span>6s</span>
      <span>8s</span>
      <span>10s</span>
    </div>

    <div class="quant-lane-wrap">
      <div class="quant-playhead" id="quantPlayhead"></div>

      <div class="quant-lane">
        <div class="quant-lane__label">量化系统</div>
        <div class="quant-track">
          <div class="quant-window" data-start="1" data-end="3">信号窗口</div>
          <div class="quant-event" data-start="1.2" data-end="1.7">买入#1</div>
          <div class="quant-event" data-start="2.4" data-end="2.9">卖出#1</div>
          <div class="quant-event" data-start="4.1" data-end="4.5">买入#2</div>
          <div class="quant-event" data-start="4.6" data-end="5.0">卖出#2</div>
          <div class="quant-event" data-start="8.2" data-end="8.8">买入#3</div>
          <div class="quant-event" data-start="9.1" data-end="9.8">卖出#3</div>
        </div>
      </div>

      <div class="quant-lane">
        <div class="quant-lane__label">散户</div>
        <div class="quant-track">
          <div class="quant-idle">观察行情中...</div>
        </div>
      </div>
    </div>
  </div>

  <div class="chart-card">
    <h3 class="mb-3 text-lg font-semibold">风险地图：常见度与破坏性</h3>
    <p class="mb-4 text-sm text-foreground/70">
      越靠右越常见，越靠上代表一旦发生影响越大。用于确定优先防守顺序。
    </p>
    <canvas id="riskMatrixChart"></canvas>
  </div>
</section>

<script is:inline data-astro-rerun>
  (async function () {
    const stateKey = "__chapter2State";

    function destroyPreviousState() {
      const previous = window[stateKey];
      if (previous?.cleanup) {
        previous.cleanup();
      }
      window[stateKey] = { cleanup: () => {} };
    }

    function loadChartJs() {
      if (window.Chart) return Promise.resolve(window.Chart);

      return new Promise((resolve, reject) => {
        const existing = document.querySelector(
          'script[data-chartjs-loader="true"]'
        );
        if (existing) {
          existing.addEventListener("load", () => resolve(window.Chart), {
            once: true,
          });
          existing.addEventListener(
            "error",
            () => reject(new Error("Chart.js load failed")),
            {
              once: true,
            }
          );
          return;
        }

        const script = document.createElement("script");
        script.src =
          "https://cdn.jsdelivr.net/npm/chart.js@4.4.8/dist/chart.umd.min.js";
        script.async = true;
        script.dataset.chartjsLoader = "true";
        script.onload = () => resolve(window.Chart);
        script.onerror = () => reject(new Error("Chart.js load failed"));
        document.head.appendChild(script);
      });
    }

    function destroyChartIfExists(Chart, canvas) {
      if (!Chart || !canvas) return;
      const existing = Chart.getChart(canvas);
      if (existing) existing.destroy();
    }

    async function initTriangleChart(Chart) {
      const canvas = document.getElementById("triangleChart");
      const legend = document.getElementById("triangleLegend");
      if (!canvas || !legend) return null;

      const assets = [
        { name: "货币基金 / 现金管理", values: [9, 9, 3], color: "#3b82f6" },
        { name: "中短债基金", values: [8, 7, 4], color: "#10b981" },
        { name: "高股息 / 红利资产", values: [6, 6, 6], color: "#ea580c" },
        { name: "宽基股票 ETF", values: [4, 6, 8], color: "#e11d48" },
        { name: "黄金 / 商品 ETF", values: [5, 5, 7], color: "#ca8a04" },
        { name: "私募 / 小众策略", values: [3, 2, 8], color: "#7c3aed" },
      ];

      legend.innerHTML = assets
        .map(
          item =>
            `<span class="triangle-legend__item"><i style="background:${item.color}"></i>${item.name}</span>`
        )
        .join("");

      destroyChartIfExists(Chart, canvas);

      return new Chart(canvas, {
        type: "radar",
        data: {
          labels: ["安全性", "流动性", "收益潜力"],
          datasets: assets.map(item => ({
            label: item.name,
            data: item.values,
            borderColor: item.color,
            backgroundColor: `${item.color}1f`,
            pointRadius: 2.5,
            borderWidth: 2,
          })),
        },
        options: {
          animation: false,
          responsive: true,
          maintainAspectRatio: false,
          interaction: { mode: "nearest", intersect: false },
          plugins: {
            title: {
              display: true,
              text: "常见资产在三角三端的取舍分布",
            },
            legend: { display: false },
          },
          scales: {
            r: {
              min: 0,
              max: 10,
              ticks: { stepSize: 2, backdropColor: "transparent" },
              pointLabels: { font: { size: 12 } },
              grid: { color: "rgba(148, 163, 184, 0.28)" },
              angleLines: { color: "rgba(148, 163, 184, 0.32)" },
            },
          },
        },
      });
    }

    function initQuantScene() {
      const root = document.getElementById("quantScene");
      const playhead = document.getElementById("quantPlayhead");
      const caption = document.getElementById("quantSceneCaption");
      if (!root || !playhead || !caption) return () => {};

      const reduceMotion = window.matchMedia(
        "(prefers-reduced-motion: reduce)"
      ).matches;
      const duration = 10;
      const signal = root.querySelector(".quant-window");
      const events = Array.from(root.querySelectorAll(".quant-event")).map(
        el => ({
          el,
          start: Number(el.dataset.start || 0),
          end: Number(el.dataset.end || 0),
          text: el.textContent?.trim() || "动作",
        })
      );

      function placeByTime(element, start, end) {
        const left = Math.max(0, Math.min(100, (start / duration) * 100));
        const width = Math.max(1.2, ((end - start) / duration) * 100);
        element.style.left = `${left}%`;
        element.style.width = `${width}%`;
      }

      if (signal) {
        placeByTime(
          signal,
          Number(signal.dataset.start || 1),
          Number(signal.dataset.end || 3)
        );
      }
      events.forEach(item => placeByTime(item.el, item.start, item.end));

      if (reduceMotion) {
        playhead.style.left = "10%";
        caption.textContent =
          "检测到减少动态效果设置：已暂停动画，仅保留静态时间轴";
        return () => {};
      }

      let rafId = 0;
      let lastPaint = 0;
      let isVisible = !document.hidden;
      const startedAt = performance.now();

      function render(now) {
        if (!isVisible || !document.body.contains(root)) return;

        if (now - lastPaint < 120) {
          rafId = requestAnimationFrame(render);
          return;
        }
        lastPaint = now;

        const elapsed = ((now - startedAt) / 1000) % duration;
        const progress = elapsed / duration;
        playhead.style.left = `${(progress * 100).toFixed(2)}%`;

        let text = `第 ${elapsed.toFixed(1)} 秒：散户观察行情`;
        if (elapsed >= 1 && elapsed <= 3) {
          text = `第 ${elapsed.toFixed(1)} 秒：信号触发，量化开始执行`;
        }

        events.forEach(item => {
          const active = elapsed >= item.start && elapsed <= item.end;
          item.el.classList.toggle("is-active", active);
          if (active)
            text = `第 ${elapsed.toFixed(1)} 秒：量化执行 ${item.text}`;
        });

        caption.textContent = text;
        rafId = requestAnimationFrame(render);
      }

      function onVisibilityChange() {
        isVisible = !document.hidden;
        if (isVisible && !rafId) {
          rafId = requestAnimationFrame(render);
        }
        if (!isVisible && rafId) {
          cancelAnimationFrame(rafId);
          rafId = 0;
        }
      }

      document.addEventListener("visibilitychange", onVisibilityChange);
      rafId = requestAnimationFrame(render);

      return () => {
        if (rafId) cancelAnimationFrame(rafId);
        events.forEach(item => item.el.classList.remove("is-active"));
        document.removeEventListener("visibilitychange", onVisibilityChange);
      };
    }

    async function initRiskMatrixChart(Chart) {
      const canvas = document.getElementById("riskMatrixChart");
      if (!canvas) return null;

      const risks = [
        { x: 8, y: 9, r: 11, name: "行为风险", color: "#ef4444" },
        { x: 7, y: 8, r: 10, name: "市场风险", color: "#f97316" },
        { x: 6, y: 7, r: 9, name: "流动性风险", color: "#eab308" },
        { x: 4, y: 8, r: 8, name: "杠杆风险", color: "#8b5cf6" },
        { x: 3, y: 6, r: 7, name: "信用风险", color: "#3b82f6" },
      ];

      destroyChartIfExists(Chart, canvas);

      return new Chart(canvas, {
        type: "bubble",
        data: {
          datasets: risks.map(item => ({
            label: item.name,
            data: [{ x: item.x, y: item.y, r: item.r }],
            backgroundColor: `${item.color}aa`,
            borderColor: item.color,
            borderWidth: 1.5,
            hoverBorderWidth: 2,
          })),
        },
        options: {
          animation: false,
          responsive: true,
          maintainAspectRatio: false,
          plugins: {
            legend: { position: "top" },
            tooltip: {
              callbacks: {
                label: ctx => {
                  const p = ctx.raw;
                  return `${ctx.dataset.label}: 常见度 ${p.x}/10, 破坏性 ${p.y}/10`;
                },
              },
            },
          },
          scales: {
            x: {
              min: 0,
              max: 10,
              title: { display: true, text: "常见度" },
              grid: { color: "rgba(148, 163, 184, 0.25)" },
            },
            y: {
              min: 0,
              max: 10,
              title: { display: true, text: "破坏性" },
              grid: { color: "rgba(148, 163, 184, 0.25)" },
            },
          },
        },
      });
    }

    destroyPreviousState();

    const Chart = await loadChartJs().catch(() => null);
    if (!Chart) return;

    const triangleChart = await initTriangleChart(Chart);
    const riskChart = await initRiskMatrixChart(Chart);
    const disposeQuant = initQuantScene();

    window[stateKey] = {
      cleanup: () => {
        disposeQuant();
        if (triangleChart) triangleChart.destroy();
        if (riskChart) riskChart.destroy();
      },
    };
  })();
</script>
