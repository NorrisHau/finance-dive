---
import { render, type CollectionEntry } from "astro:content";
import Layout from "@/layouts/Layout.astro";
import Header from "@/components/Header.astro";
import Footer from "@/components/Footer.astro";
import Tag from "@/components/Tag.astro";
import Datetime from "@/components/Datetime.astro";
import EditPost from "@/components/EditPost.astro";
import ShareLinks from "@/components/ShareLinks.astro";
import BackButton from "@/components/BackButton.astro";
import BackToTopButton from "@/components/BackToTopButton.astro";
import { getPath } from "@/utils/getPath";
import { slugifyStr } from "@/utils/slugify";
import IconChevronLeft from "@/assets/icons/IconChevronLeft.svg";
import IconChevronRight from "@/assets/icons/IconChevronRight.svg";
import { SITE } from "@/config";

type Props = {
  post: CollectionEntry<"blog">;
  posts: CollectionEntry<"blog">[];
};

const { post, posts } = Astro.props;

const {
  title,
  author,
  description,
  ogImage: initOgImage,
  canonicalURL,
  pubDatetime,
  modDatetime,
  timezone,
  tags,
  hideEditPost,
} = post.data;

const { Content } = await render(post);

let ogImageUrl: string | undefined;

// Determine OG image source
if (typeof initOgImage === "string") {
  ogImageUrl = initOgImage; // Remote OG image (absolute URL)
} else if (initOgImage?.src) {
  ogImageUrl = initOgImage.src; // Local asset
}

// Use dynamic OG image if enabled and no remote|local ogImage
if (!ogImageUrl && SITE.dynamicOgImage) {
  ogImageUrl = `${getPath(post.id, post.filePath)}/index.png`;
}

// Resolve OG image URL (or fallback to SITE.ogImage / default `og.png`)
const ogImage = ogImageUrl
  ? new URL(ogImageUrl, Astro.url.origin).href
  : undefined;

const layoutProps = {
  title: `${title} | ${SITE.title}`,
  author,
  description,
  pubDatetime,
  modDatetime,
  canonicalURL,
  ogImage,
  scrollSmooth: true,
};

/* ========== Prev/Next Posts ========== */

const allPosts = posts.map(({ data: { title }, id, filePath }) => ({
  id,
  title,
  filePath,
}));

const currentPostIndex = allPosts.findIndex(a => a.id === post.id);

const prevPost = currentPostIndex !== 0 ? allPosts[currentPostIndex - 1] : null;
const nextPost =
  currentPostIndex !== allPosts.length ? allPosts[currentPostIndex + 1] : null;
---

<Layout {...layoutProps}>
  <Header />
  <BackButton />
  <main
    id="main-content"
    class:list={["app-layout pb-12", { "mt-8": !SITE.showBackButton }]}
    data-pagefind-body
  >
    <h1
      transition:name={slugifyStr(title.replaceAll(".", "-"))}
      class="inline-block text-2xl font-bold text-accent sm:text-3xl"
    >
      {title}
    </h1>
    <div class="my-2 flex items-center gap-2">
      <Datetime {pubDatetime} {modDatetime} {timezone} size="lg" />
      <span
        aria-hidden="true"
        class:list={[
          "max-sm:hidden",
          { hidden: !SITE.editPost.enabled || hideEditPost },
        ]}>|</span
      >
      <EditPost {hideEditPost} {post} class="max-sm:hidden" />
    </div>
    <article
      id="article"
      class="app-prose mt-8 w-full max-w-app prose-pre:bg-(--shiki-light-bg) dark:prose-pre:bg-(--shiki-dark-bg)"
    >
      <Content />
    </article>

    <hr class="my-8 border-dashed" />

    <EditPost class="sm:hidden" {hideEditPost} {post} />

    <ul class="mt-4 mb-8 flex flex-wrap gap-4 sm:my-8">
      {tags.map(tag => <Tag tag={slugifyStr(tag)} tagName={tag} size="sm" />)}
    </ul>

    <BackToTopButton />

    <ShareLinks />

    <hr class="my-6 border-dashed" />

    <!-- Previous/Next Post Buttons -->
    <div data-pagefind-ignore class="grid grid-cols-1 gap-6 sm:grid-cols-2">
      {
        prevPost && (
          <a
            href={getPath(prevPost.id, prevPost.filePath)}
            class="flex w-full gap-1 hover:opacity-75"
          >
            <IconChevronLeft class="inline-block flex-none rtl:rotate-180" />
            <div>
              <span>Previous Post</span>
              <div class="text-sm text-accent/85">{prevPost.title}</div>
            </div>
          </a>
        )
      }
      {
        nextPost && (
          <a
            href={getPath(nextPost.id, nextPost.filePath)}
            class="flex w-full justify-end gap-1 text-end hover:opacity-75 sm:col-start-2"
          >
            <div>
              <span>Next Post</span>
              <div class="text-sm text-accent/85">{nextPost.title}</div>
            </div>
            <IconChevronRight class="inline-block flex-none rtl:rotate-180" />
          </a>
        )
      }
    </div>
  </main>
  <Footer />
</Layout>

<script is:inline data-astro-rerun>
  /** Create a progress indicator
   *  at the top */
  function createProgressBar() {
    // Create the main container div
    const progressContainer = document.createElement("div");
    progressContainer.className =
      "progress-container fixed top-0 z-10 h-1 w-full bg-background";

    // Create the progress bar div
    const progressBar = document.createElement("div");
    progressBar.className = "progress-bar h-1 w-0 bg-accent";
    progressBar.id = "myBar";

    // Append the progress bar to the progress container
    progressContainer.appendChild(progressBar);

    // Append the progress container to the document body or any other desired parent element
    document.body.appendChild(progressContainer);
  }
  createProgressBar();

  /** Update the progress bar
   *  when user scrolls */
  function updateScrollProgress() {
    document.addEventListener("scroll", () => {
      const winScroll =
        document.body.scrollTop || document.documentElement.scrollTop;
      const height =
        document.documentElement.scrollHeight -
        document.documentElement.clientHeight;
      const scrolled = (winScroll / height) * 100;
      if (document) {
        const myBar = document.getElementById("myBar");
        if (myBar) {
          myBar.style.width = scrolled + "%";
        }
      }
    });
  }
  updateScrollProgress();

  /** Attaches links to headings in the document,
   *  allowing sharing of sections easily */
  function addHeadingLinks() {
    const headings = Array.from(
      document.querySelectorAll("h2, h3, h4, h5, h6")
    );
    for (const heading of headings) {
      heading.classList.add("group");
      const link = document.createElement("a");
      link.className =
        "heading-link ms-2 no-underline opacity-75 md:opacity-0 md:group-hover:opacity-100 md:focus:opacity-100";
      link.href = "#" + heading.id;

      const span = document.createElement("span");
      span.ariaHidden = "true";
      span.innerText = "#";
      link.appendChild(span);
      heading.appendChild(link);
    }
  }
  addHeadingLinks();

  /** Attaches copy buttons to code blocks in the document,
   * allowing users to copy code easily. */
  function attachCopyButtons() {
    const copyButtonLabel = "Copy";
    const codeBlocks = Array.from(document.querySelectorAll("pre"));

    for (const codeBlock of codeBlocks) {
      const wrapper = document.createElement("div");
      wrapper.style.position = "relative";

      // Check if --file-name-offset custom property exists
      const computedStyle = getComputedStyle(codeBlock);
      const hasFileNameOffset =
        computedStyle.getPropertyValue("--file-name-offset").trim() !== "";

      // Determine the top positioning class
      const topClass = hasFileNameOffset
        ? "top-(--file-name-offset)"
        : "-top-3";

      const copyButton = document.createElement("button");
      copyButton.className = `copy-code absolute end-3 ${topClass} rounded bg-muted border border-muted px-2 py-1 text-xs leading-4 text-foreground font-medium`;
      copyButton.innerHTML = copyButtonLabel;
      codeBlock.setAttribute("tabindex", "0");
      codeBlock.appendChild(copyButton);

      // wrap codebock with relative parent element
      codeBlock?.parentNode?.insertBefore(wrapper, codeBlock);
      wrapper.appendChild(codeBlock);

      copyButton.addEventListener("click", async () => {
        await copyCode(codeBlock, copyButton);
      });
    }

    async function copyCode(block, button) {
      const code = block.querySelector("code");
      const text = code?.innerText;

      await navigator.clipboard.writeText(text ?? "");

      // visual feedback that task is completed
      button.innerText = "Copied";

      setTimeout(() => {
        button.innerText = copyButtonLabel;
      }, 700);
    }
  }
  attachCopyButtons();

  async function loadChartJs() {
    if (window.Chart) return window.Chart;

    await new Promise((resolve, reject) => {
      const existingScript = document.querySelector(
        'script[data-chartjs-loader="true"]'
      );
      if (existingScript) {
        existingScript.addEventListener("load", () => resolve(true), {
          once: true,
        });
        existingScript.addEventListener("error", () => reject(false), {
          once: true,
        });
        return;
      }

      const script = document.createElement("script");
      script.src =
        "https://cdn.jsdelivr.net/npm/chart.js@4.4.8/dist/chart.umd.min.js";
      script.async = true;
      script.dataset.chartjsLoader = "true";
      script.onload = () => resolve(true);
      script.onerror = () => reject(false);
      document.head.appendChild(script);
    });

    return window.Chart;
  }

  async function renderFinanceChapterCharts() {
    const inflationCanvas = document.getElementById("inflationChart");
    const compoundCanvas = document.getElementById("compoundInteractiveChart");
    const triangleCanvas = document.getElementById("triangleChart");
    const marketPlayersCanvas = document.getElementById("marketPlayersChart");
    const quantTimelineCanvas = document.getElementById("quantTimelineChart");

    if (
      !inflationCanvas &&
      !compoundCanvas &&
      !triangleCanvas &&
      !marketPlayersCanvas &&
      !quantTimelineCanvas
    )
      return;

    const Chart = await loadChartJs();
    if (!Chart) return;

    if (inflationCanvas && !inflationCanvas.dataset.chartRendered) {
      const years = Array.from({ length: 31 }, (_, i) => i);
      const inflation3 = years.map(y => 100 * Math.pow(1 - 0.03, y));
      const inflation5 = years.map(y => 100 * Math.pow(1 - 0.05, y));

      new Chart(inflationCanvas, {
        type: "line",
        data: {
          labels: years.map(y => `第 ${y} 年`),
          datasets: [
            {
              label: "3% 通胀下购买力（万元）",
              data: inflation3,
              borderColor: "rgba(52, 211, 153, 1)",
              backgroundColor: "rgba(52, 211, 153, 0.16)",
              fill: true,
              tension: 0.28,
            },
            {
              label: "5% 通胀下购买力（万元）",
              data: inflation5,
              borderColor: "rgba(248, 113, 113, 1)",
              backgroundColor: "rgba(248, 113, 113, 0.14)",
              fill: true,
              tension: 0.28,
            },
          ],
        },
        options: {
          responsive: true,
          interaction: { mode: "index", intersect: false },
          plugins: {
            title: {
              display: true,
              text: "100万元购买力在30年中的变化（通胀情景）",
            },
          },
          scales: {
            y: {
              beginAtZero: true,
              title: { display: true, text: "购买力（万元）" },
            },
            x: {
              title: { display: true, text: "时间（年）" },
            },
          },
        },
      });

      inflationCanvas.dataset.chartRendered = "true";
    }

    if (compoundCanvas && !compoundCanvas.dataset.chartRendered) {
      const principalInput = document.getElementById("initialPrincipalInput");
      const contributionInput = document.getElementById(
        "annualContributionInput"
      );
      const targetReturnInput = document.getElementById("targetReturnInput");
      const years = Array.from({ length: 31 }, (_, i) => i);

      const calculatePath = (principal, annualContribution, ratePercent) => {
        const rate = ratePercent / 100;
        let value = principal;
        return years.map((_, idx) => {
          if (idx === 0) return value;
          value = value * (1 + rate) + annualContribution;
          return value;
        });
      };

      const parseNumber = (value, fallback) => {
        const num = Number(value);
        return Number.isFinite(num) ? num : fallback;
      };

      const buildData = () => {
        const principal = parseNumber(principalInput?.value, 20000);
        const annualContribution = parseNumber(contributionInput?.value, 12000);
        const targetReturn = parseNumber(targetReturnInput?.value, 6);

        return {
          labels: years.map(y => `第 ${y} 年`),
          datasets: [
            {
              label: "2%（保守情景）",
              data: calculatePath(principal, annualContribution, 2),
              borderColor: "rgba(148, 163, 184, 1)",
              tension: 0.25,
            },
            {
              label: `目标收益率 ${targetReturn.toFixed(1)}%`,
              data: calculatePath(principal, annualContribution, targetReturn),
              borderColor: "rgba(59, 130, 246, 1)",
              backgroundColor: "rgba(59, 130, 246, 0.14)",
              fill: true,
              tension: 0.25,
            },
            {
              label: "8%（进取情景）",
              data: calculatePath(principal, annualContribution, 8),
              borderColor: "rgba(16, 185, 129, 1)",
              tension: 0.25,
            },
          ],
        };
      };

      const compoundChart = new Chart(compoundCanvas, {
        type: "line",
        data: buildData(),
        options: {
          responsive: true,
          interaction: { mode: "index", intersect: false },
          plugins: {
            title: {
              display: true,
              text: "30年资金增长对比：可调本金、年储蓄与目标收益率",
            },
            tooltip: {
              callbacks: {
                label: context =>
                  `${context.dataset.label}：¥${Math.round(context.parsed.y).toLocaleString()}`,
              },
            },
          },
          scales: {
            y: {
              title: { display: true, text: "总资产（元）" },
              ticks: {
                callback: value => `¥${Number(value).toLocaleString()}`,
              },
            },
            x: { title: { display: true, text: "时间（年）" } },
          },
        },
      });

      [principalInput, contributionInput, targetReturnInput].forEach(input => {
        input?.addEventListener("input", () => {
          compoundChart.data = buildData();
          compoundChart.update();
        });
      });

      compoundCanvas.dataset.chartRendered = "true";
    }

    if (triangleCanvas && !triangleCanvas.dataset.chartRendered) {
      new Chart(triangleCanvas, {
        type: "radar",
        data: {
          labels: ["安全性", "流动性", "收益潜力"],
          datasets: [
            {
              label: "货币类/现金管理",
              data: [9, 9, 3],
              borderColor: "rgba(148, 163, 184, 1)",
              backgroundColor: "rgba(148, 163, 184, 0.18)",
            },
            {
              label: "债券基金",
              data: [7, 6, 5],
              borderColor: "rgba(59, 130, 246, 1)",
              backgroundColor: "rgba(59, 130, 246, 0.14)",
            },
            {
              label: "股票/权益ETF",
              data: [4, 6, 8],
              borderColor: "rgba(16, 185, 129, 1)",
              backgroundColor: "rgba(16, 185, 129, 0.14)",
            },
          ],
        },
        options: {
          responsive: true,
          plugins: {
            title: {
              display: true,
              text: "不可能三角示意：不同工具的取舍分布",
            },
          },
          scales: {
            r: {
              beginAtZero: true,
              max: 10,
              ticks: { stepSize: 2 },
            },
          },
        },
      });

      triangleCanvas.dataset.chartRendered = "true";
    }

    if (marketPlayersCanvas && !marketPlayersCanvas.dataset.chartRendered) {
      new Chart(marketPlayersCanvas, {
        type: "bar",
        data: {
          labels: ["散户", "量化策略", "公募基金", "私募基金"],
          datasets: [
            {
              label: "速度优势",
              data: [3, 10, 6, 7],
              backgroundColor: "rgba(244, 114, 182, 0.65)",
            },
            {
              label: "耐心与时间优势",
              data: [8, 4, 5, 6],
              backgroundColor: "rgba(96, 165, 250, 0.7)",
            },
          ],
        },
        options: {
          responsive: true,
          plugins: {
            title: {
              display: true,
              text: "市场参与者能力维度（示意）：速度 vs 长期耐心",
            },
          },
          scales: {
            y: {
              beginAtZero: true,
              max: 10,
              title: { display: true, text: "相对优势评分" },
            },
          },
        },
      });

      marketPlayersCanvas.dataset.chartRendered = "true";
    }

    if (quantTimelineCanvas && !quantTimelineCanvas.dataset.chartRendered) {
      new Chart(quantTimelineCanvas, {
        type: "line",
        data: {
          labels: ["0ms", "8ms", "15ms", "30ms", "60ms", "120ms"],
          datasets: [
            {
              label: "量化系统累计动作数（示意）",
              data: [0, 1, 3, 6, 9, 12],
              borderColor: "rgba(59, 130, 246, 1)",
              backgroundColor: "rgba(59, 130, 246, 0.14)",
              fill: true,
              tension: 0.2,
            },
            {
              label: "普通手动交易累计动作数（示意）",
              data: [0, 0, 0, 1, 1, 2],
              borderColor: "rgba(148, 163, 184, 1)",
              tension: 0.2,
            },
          ],
        },
        options: {
          responsive: true,
          plugins: {
            title: {
              display: true,
              text: "量化与手动交易执行时间轴对比（示意）",
            },
          },
          scales: {
            y: {
              beginAtZero: true,
              title: { display: true, text: "完成动作数量" },
            },
            x: {
              title: { display: true, text: "从信号触发开始的时间" },
            },
          },
        },
      });

      quantTimelineCanvas.dataset.chartRendered = "true";
    }
  }

  renderFinanceChapterCharts();

  /* Go to page start after page swap */
  document.addEventListener("astro:after-swap", () =>
    window.scrollTo({ left: 0, top: 0, behavior: "instant" })
  );
</script>
