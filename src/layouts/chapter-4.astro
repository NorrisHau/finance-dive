---
// src/layouts/chapter-4.astro
---
<div class="chapter-interactive-section mt-12 pt-8 border-t border-dashed border-skin-line">
  <h3 class="text-xl font-bold mb-4">互动图表：量化与手动交易时间轴对比</h3>
  <div class="chart-card bg-skin-card p-4 rounded-lg">
    <canvas id="quantTimelineChart"></canvas>
  </div>
</div>

<script is:inline data-astro-rerun>
  (async function() {
    if (!window.Chart) {
      await new Promise((resolve) => {
        const script = document.createElement("script");
        script.src = "https://cdn.jsdelivr.net/npm/chart.js@4.4.8/dist/chart.umd.min.js";
        script.onload = resolve;
        document.head.appendChild(script);
      });
    }

    const Chart = window.Chart;
    if(!Chart) return;
    
    const quantTimelineCanvas = document.getElementById("quantTimelineChart");
    if (quantTimelineCanvas && !quantTimelineCanvas.dataset.chartRendered) {
      new Chart(quantTimelineCanvas, {
        type: "line",
        data: {
          labels: ["0ms", "8ms", "15ms", "30ms", "60ms", "120ms"],
          datasets: [
            {
              label: "量化系统累计动作数（示意）",
              data: [0, 1, 3, 6, 9, 12],
              borderColor: "rgba(59, 130, 246, 1)",
              backgroundColor: "rgba(59, 130, 246, 0.14)",
              fill: true,
              tension: 0.2,
            },
            {
              label: "普通手动交易累计动作数（示意）",
              data: [0, 0, 0, 1, 1, 2],
              borderColor: "rgba(148, 163, 184, 1)",
              tension: 0.2,
            },
          ],
        },
        options: {
          responsive: true,
          plugins: {
            title: { display: true, text: "量化与手动交易执行时间轴对比（示意）" },
          },
          scales: {
            y: { beginAtZero: true, title: { display: true, text: "完成动作数量" } },
            x: { title: { display: true, text: "从信号触发开始的时间" } },
          },
        },
      });
      quantTimelineCanvas.dataset.chartRendered = "true";
    }
  })();
</script>
