---
// src/layouts/chapter-3.astro
// 第三章固定参数对比图：初始50000，每月新增4000，1%/5%/8%
---

<div class="chapter-interactive-section mt-12 border-t border-dashed border-skin-line pt-8">
  <h3 class="mb-4 text-xl font-bold">30年复利对比（固定参数）</h3>
  <p class="mb-6 text-sm text-foreground/70">
    固定条件：初始资金 50,000 元，每月新增 4,000 元。对比普通存入余额宝（1%）、理财（5%）、进阶理财（8%）。
  </p>
  <div class="chart-card bg-skin-card p-4">
    <canvas id="chapter3FixedComparisonChart"></canvas>
  </div>
</div>

<script is:inline data-astro-rerun>
  (async function () {
    function loadChartJs() {
      if (window.Chart) return Promise.resolve(window.Chart);
      return new Promise((resolve, reject) => {
        const existing = document.querySelector('script[data-chartjs-loader="true"]');
        if (existing) {
          existing.addEventListener("load", () => resolve(window.Chart), { once: true });
          existing.addEventListener("error", () => reject(new Error("Chart.js load failed")), {
            once: true,
          });
          return;
        }

        const script = document.createElement("script");
        script.src = "https://cdn.jsdelivr.net/npm/chart.js@4.4.8/dist/chart.umd.min.js";
        script.async = true;
        script.dataset.chartjsLoader = "true";
        script.onload = () => resolve(window.Chart);
        script.onerror = () => reject(new Error("Chart.js load failed"));
        document.head.appendChild(script);
      });
    }

    const Chart = await loadChartJs().catch(() => null);
    if (!Chart) return;

    const canvas = document.getElementById("chapter3FixedComparisonChart");
    if (!canvas) return;

    const initial = 50000;
    const monthly = 4000;
    const yearly = monthly * 12;
    const years = Array.from({ length: 31 }, (_, i) => i);

    function growthSeries(rate) {
      return years.map(y => {
        if (y === 0) return initial;
        const p = initial * Math.pow(1 + rate, y);
        const c = yearly * ((Math.pow(1 + rate, y) - 1) / rate);
        return p + c;
      });
    }

    const series1 = growthSeries(0.01);
    const series5 = growthSeries(0.05);
    const series8 = growthSeries(0.08);

    const nf = new Intl.NumberFormat("zh-CN");

    new Chart(canvas, {
      type: "line",
      data: {
        labels: years.map(y => `第${y}年`),
        datasets: [
          {
            label: "普通存入余额宝（1%）",
            data: series1,
            borderColor: "#94a3b8",
            tension: 0.35,
            fill: false,
          },
          {
            label: "理财（5%）",
            data: series5,
            borderColor: "#3b82f6",
            backgroundColor: "rgba(59,130,246,0.14)",
            tension: 0.35,
            fill: true,
          },
          {
            label: "进阶理财（8%）",
            data: series8,
            borderColor: "#10b981",
            tension: 0.35,
            fill: false,
          },
        ],
      },
      options: {
        responsive: true,
        maintainAspectRatio: false,
        interaction: { mode: "index", intersect: false },
        plugins: {
          title: { display: true, text: "固定参数下的30年资产曲线" },
          tooltip: {
            callbacks: {
              label: ctx => `${ctx.dataset.label}：¥${nf.format(Math.round(ctx.parsed.y || 0))}`,
            },
          },
        },
        scales: {
          y: {
            beginAtZero: true,
            ticks: {
              callback: value => `¥${nf.format(Math.round(Number(value) || 0))}`,
            },
            title: { display: true, text: "资产规模（元）" },
          },
          x: {
            title: { display: true, text: "时间" },
          },
        },
      },
    });
  })();
</script>
