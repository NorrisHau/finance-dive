---
// src/layouts/chapter-3.astro
---
<div class="chapter-interactive-section mt-12 pt-8 border-t border-dashed border-skin-line">
  <h3 class="text-xl font-bold mb-4">互动图表：市场参与者的能力维度</h3>
  <div class="chart-card bg-skin-card p-4 rounded-lg">
    <canvas id="marketPlayersChart"></canvas>
  </div>
</div>

<script is:inline data-astro-rerun>
  (async function() {
    if (!window.Chart) {
      await new Promise((resolve) => {
        const script = document.createElement("script");
        script.src = "https://cdn.jsdelivr.net/npm/chart.js@4.4.8/dist/chart.umd.min.js";
        script.onload = resolve;
        document.head.appendChild(script);
      });
    }

    const Chart = window.Chart;
    if(!Chart) return;
    
    const marketPlayersCanvas = document.getElementById("marketPlayersChart");
    if (marketPlayersCanvas && !marketPlayersCanvas.dataset.chartRendered) {
      new Chart(marketPlayersCanvas, {
        type: "bar",
        data: {
          labels: ["散户", "量化策略", "公募基金", "私募基金"],
          datasets: [
            {
              label: "速度优势",
              data: [3, 10, 6, 7],
              backgroundColor: "rgba(244, 114, 182, 0.65)",
            },
            {
              label: "耐心与时间优势",
              data: [8, 4, 5, 6],
              backgroundColor: "rgba(96, 165, 250, 0.7)",
            },
          ],
        },
        options: {
          responsive: true,
          plugins: {
            title: { display: true, text: "市场参与者能力维度（示意）：速度 vs 长期耐心" },
          },
          scales: {
            y: { beginAtZero: true, max: 10, title: { display: true, text: "相对优势评分" } },
          },
        },
      });
      marketPlayersCanvas.dataset.chartRendered = "true";
    }
  })();
</script>
