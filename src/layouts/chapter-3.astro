---
// src/layouts/chapter-3.astro
// 第三章交互图表：
// 1) 30年复利曲线（1% / 5% / 8%）
// 2) 工具风险收益雷达图（现金/债券/ETF/个股/杠杆）
---

<div
  class="chapter-interactive-section border-skin-line mt-12 space-y-8 border-t border-dashed pt-8"
>
  <section>
    <h3 class="mb-4 text-xl font-bold">30年复利对比（固定参数）</h3>
    <p class="mb-6 text-sm text-foreground/70">
      固定条件：初始资金 50,000 元，每月新增 4,000
      元。对比现金管理（1%）、稳健配置（5%）、进阶配置（8%）。
    </p>
    <div class="chart-card bg-skin-card p-4">
      <canvas id="chapter3FixedComparisonChart"></canvas>
    </div>
  </section>

  <section>
    <h3 class="mb-4 text-xl font-bold">工具画像：收益潜力、波动、复杂度</h3>
    <p class="mb-6 text-sm text-foreground/70">
      分数用于学习示意（1~10）：帮助你理解“好工具”要和能力圈匹配，而不是只看收益想象。
    </p>
    <div class="chart-card bg-skin-card p-4">
      <canvas id="chapter3ToolProfileChart"></canvas>
    </div>
  </section>
</div>

<script is:inline data-astro-rerun>
  (async function () {
    const stateKey = "__chapter3State";

    function destroyPreviousState() {
      const previous = window[stateKey];
      if (previous?.cleanup) previous.cleanup();
      window[stateKey] = { cleanup: () => {} };
    }

    function loadChartJs() {
      if (window.Chart) return Promise.resolve(window.Chart);

      return new Promise((resolve, reject) => {
        const existing = document.querySelector(
          'script[data-chartjs-loader="true"]'
        );
        if (existing) {
          existing.addEventListener("load", () => resolve(window.Chart), {
            once: true,
          });
          existing.addEventListener(
            "error",
            () => reject(new Error("Chart.js load failed")),
            { once: true }
          );
          return;
        }

        const script = document.createElement("script");
        script.src =
          "https://cdn.jsdelivr.net/npm/chart.js@4.4.8/dist/chart.umd.min.js";
        script.async = true;
        script.dataset.chartjsLoader = "true";
        script.onload = () => resolve(window.Chart);
        script.onerror = () => reject(new Error("Chart.js load failed"));
        document.head.appendChild(script);
      });
    }

    function destroyChartIfExists(Chart, canvas) {
      if (!Chart || !canvas) return;
      const existing = Chart.getChart(canvas);
      if (existing) existing.destroy();
    }

    function buildCompoundChart(Chart) {
      const canvas = document.getElementById("chapter3FixedComparisonChart");
      if (!canvas) return null;

      destroyChartIfExists(Chart, canvas);

      const initial = 50000;
      const monthly = 4000;
      const yearly = monthly * 12;
      const years = Array.from({ length: 31 }, (_, i) => i);

      function growthSeries(rate) {
        return years.map(y => {
          if (y === 0) return initial;
          const principal = initial * Math.pow(1 + rate, y);
          const contribution = yearly * ((Math.pow(1 + rate, y) - 1) / rate);
          return principal + contribution;
        });
      }

      const low = growthSeries(0.01);
      const mid = growthSeries(0.05);
      const high = growthSeries(0.08);
      const nf = new Intl.NumberFormat("zh-CN");

      return new Chart(canvas, {
        type: "line",
        data: {
          labels: years.map(y => `第${y}年`),
          datasets: [
            {
              label: "现金管理（1%）",
              data: low,
              borderColor: "#94a3b8",
              tension: 0.35,
              fill: false,
            },
            {
              label: "稳健配置（5%）",
              data: mid,
              borderColor: "#3b82f6",
              backgroundColor: "rgba(59,130,246,0.14)",
              tension: 0.35,
              fill: true,
            },
            {
              label: "进阶配置（8%）",
              data: high,
              borderColor: "#10b981",
              tension: 0.35,
              fill: false,
            },
          ],
        },
        options: {
          responsive: true,
          maintainAspectRatio: false,
          interaction: { mode: "index", intersect: false },
          plugins: {
            title: { display: true, text: "固定参数下的30年资产曲线" },
            tooltip: {
              callbacks: {
                label: ctx =>
                  `${ctx.dataset.label}：¥${nf.format(
                    Math.round(ctx.parsed.y || 0)
                  )}`,
              },
            },
          },
          scales: {
            y: {
              beginAtZero: true,
              ticks: {
                callback: value =>
                  `¥${nf.format(Math.round(Number(value) || 0))}`,
              },
              title: { display: true, text: "资产规模（元）" },
            },
            x: {
              title: { display: true, text: "时间" },
            },
          },
        },
      });
    }

    function buildToolProfileChart(Chart) {
      const canvas = document.getElementById("chapter3ToolProfileChart");
      if (!canvas) return null;

      destroyChartIfExists(Chart, canvas);

      return new Chart(canvas, {
        type: "radar",
        data: {
          labels: [
            "收益潜力",
            "回撤压力",
            "学习成本",
            "执行难度",
            "长期可复用",
          ],
          datasets: [
            {
              label: "现金/货基",
              data: [2, 2, 2, 2, 8],
              borderColor: "#64748b",
              backgroundColor: "rgba(100,116,139,0.18)",
              borderWidth: 2,
            },
            {
              label: "债券/债基",
              data: [4, 4, 4, 3, 8],
              borderColor: "#0ea5e9",
              backgroundColor: "rgba(14,165,233,0.18)",
              borderWidth: 2,
            },
            {
              label: "宽基ETF",
              data: [7, 6, 4, 4, 9],
              borderColor: "#10b981",
              backgroundColor: "rgba(16,185,129,0.18)",
              borderWidth: 2,
            },
            {
              label: "个股",
              data: [8, 8, 7, 7, 5],
              borderColor: "#f59e0b",
              backgroundColor: "rgba(245,158,11,0.16)",
              borderWidth: 2,
            },
            {
              label: "杠杆/衍生品",
              data: [9, 10, 9, 9, 2],
              borderColor: "#ef4444",
              backgroundColor: "rgba(239,68,68,0.15)",
              borderWidth: 2,
            },
          ],
        },
        options: {
          responsive: true,
          maintainAspectRatio: false,
          plugins: {
            legend: { position: "top" },
            title: { display: true, text: "工具选择不是比刺激，而是比匹配度" },
          },
          scales: {
            r: {
              min: 0,
              max: 10,
              ticks: { stepSize: 2, backdropColor: "transparent" },
            },
          },
        },
      });
    }

    destroyPreviousState();

    const Chart = await loadChartJs().catch(() => null);
    if (!Chart) return;

    const compoundChart = buildCompoundChart(Chart);
    const profileChart = buildToolProfileChart(Chart);

    window[stateKey] = {
      cleanup: () => {
        if (compoundChart) compoundChart.destroy();
        if (profileChart) profileChart.destroy();
      },
    };
  })();
</script>

<style>
  .chart-card {
    position: relative;
    min-height: 320px;
    border: 1px solid rgba(148, 163, 184, 0.25);
    border-radius: 0.75rem;
  }

  @media (max-width: 768px) {
    .chart-card {
      min-height: 280px;
    }
  }
</style>
