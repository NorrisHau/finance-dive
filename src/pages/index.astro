---
import { getCollection } from "astro:content";
import Layout from "@/layouts/Layout.astro";
import Header from "@/components/Header.astro";
import Footer from "@/components/Footer.astro";
import LinkButton from "@/components/LinkButton.astro";
import Card from "@/components/Card.astro";
import getSortedPosts from "@/utils/getSortedPosts";
import IconArrowRight from "@/assets/icons/IconArrowRight.svg";

const posts = await getCollection("blog");
const sortedPosts = getSortedPosts(posts);
---

<Layout>
  <Header />
  <main id="main-content" data-layout="index" class="app-layout">
    <section class="theme-hero border-b border-border py-10">
      <p class="theme-eyebrow">Nana's Wealth Log · 2026</p>
      <h1 class="theme-title">用极简框架，构建长期有效的投资系统</h1>
      <p class="theme-subtitle">
        以都市生活叙事为线索，把资产配置、风险管理与市场常识，拆解成可执行的日常动作。
      </p>

      <div class="theme-switcher" role="tablist" aria-label="内容主题">
        <button
          type="button"
          class="theme-chip is-active"
          data-theme="investment"
          role="tab"
          aria-selected="true"
          aria-controls="theme-panel-investment"
          id="theme-tab-investment"
        >
          投资
        </button>
        <button
          type="button"
          class="theme-chip"
          data-theme="technology"
          role="tab"
          aria-selected="false"
          aria-controls="theme-panel-technology"
          id="theme-tab-technology"
        >
          科技
        </button>
      </div>
    </section>

    <section
      id="theme-panel-investment"
      class="theme-panel py-10"
      role="tabpanel"
      aria-labelledby="theme-tab-investment"
    >
      <div class="mb-6 flex items-end justify-between gap-4">
        <h2 class="text-2xl font-semibold tracking-wide">投资主题</h2>
        <span class="text-sm text-foreground/60"
          >当前已上线章节：{sortedPosts.length}</span
        >
      </div>
      <ul>
        {sortedPosts.map(data => <Card variant="h3" {...data} />)}
      </ul>
    </section>

    <section
      id="theme-panel-technology"
      class="theme-panel hidden py-10"
      role="tabpanel"
      aria-labelledby="theme-tab-technology"
    >
      <div class="rounded-2xl border border-border bg-background p-6">
        <h2 class="text-2xl font-semibold tracking-wide">科技主题</h2>
        <p class="mt-3 text-foreground/70">
          科技主题内容正在整理中，后续将围绕 AI
          工具流、效率系统与职业成长持续更新。
        </p>
      </div>
    </section>

    <div class="my-8 text-center">
      <LinkButton href="/posts/">
        查看全部文章
        <IconArrowRight class="inline-block rtl:-rotate-180" />
      </LinkButton>
    </div>
  </main>
  <Footer />
</Layout>

<script>
  document.addEventListener("astro:page-load", () => {
    const indexLayout = (document.querySelector("#main-content") as HTMLElement)
      ?.dataset?.layout;
    if (indexLayout) {
      sessionStorage.setItem("backUrl", "/");
    }

    const tabs = Array.from(document.querySelectorAll(".theme-chip"));
    const panels = Array.from(document.querySelectorAll(".theme-panel"));

    const activate = (theme: string | undefined) => {
      if (!theme) return;
      tabs.forEach(tab => {
        const tabEl = tab as HTMLElement;
        const isSelected = tabEl.dataset.theme === theme;
        tabEl.classList.toggle("is-active", isSelected);
        tabEl.setAttribute("aria-selected", isSelected ? "true" : "false");
      });

      panels.forEach(panel => {
        const shouldShow = panel.id === `theme-panel-${theme}`;
        panel.classList.toggle("hidden", !shouldShow);
      });
    };

    tabs.forEach(tab => {
      const tabEl = tab as HTMLElement;
      tabEl.addEventListener("click", () => activate(tabEl.dataset.theme));
    });
  });
</script>
