---
import { getCollection } from "astro:content";
import Layout from "@/layouts/Layout.astro";
import Header from "@/components/Header.astro";
import Footer from "@/components/Footer.astro";
import LinkButton from "@/components/LinkButton.astro";
import getSortedPosts from "@/utils/getSortedPosts";
import { getPath } from "@/utils/getPath";
import { getResolvedPostCover } from "@/utils/postCovers";
import IconArrowRight from "@/assets/icons/IconArrowRight.svg";

const posts = await getCollection("blog");
const sortedPosts = getSortedPosts(posts);

type ThemeId = "investment" | "technology" | "health";

type ThemeTopic = {
  id: string;
  title: string;
  description: string;
  href?: string;
  coverImage?: string;
};

type ThemePanel = {
  id: ThemeId;
  title: string;
  subtitle?: string;
  countLabel?: string;
  items: ThemeTopic[];
};

const investmentItems: ThemeTopic[] = sortedPosts.map(({ id, data, filePath }) => {
  const explicitCover =
    typeof data.ogImage === "string" ? data.ogImage : data.ogImage?.src;
  const coverImage = getResolvedPostCover(id, explicitCover);
  const description =
    data.description.length > 96
      ? `${data.description.slice(0, 96).trim()}...`
      : data.description;

  return {
    id,
    title: data.title,
    description,
    href: getPath(id, filePath),
    coverImage,
  };
});

const technologyItems: ThemeTopic[] = [
  {
    id: "technology-ai-workflow",
    title: "AI 工具流：从输入到可复用产出",
    description: "记录个人内容工作流：选题、素材池、提示词模板、复盘看板。",
  },
  {
    id: "technology-knowledge-system",
    title: "信息系统：如何构建低摩擦知识库",
    description: "用标签、双链与检索习惯，让“收藏”真正变成“可调用”。",
  },
  {
    id: "technology-career-growth",
    title: "技术职业成长：从执行者到系统设计者",
    description: "聚焦反馈循环、复利能力和跨学科协作的成长路径。",
  },
];

const healthItems: ThemeTopic[] = [
  {
    id: "health-recovery-system",
    title: "高压工作下的恢复系统",
    description: "从睡眠、呼吸、微休息开始，建立可重复执行的恢复协议。",
  },
  {
    id: "health-minimum-workout",
    title: "运动最小行动集：忙碌也能持续",
    description: "提供 15 分钟可完成的力量+心肺组合，主打低门槛和一致性。",
  },
  {
    id: "health-energy-curve",
    title: "饮食与注意力：稳定能量曲线",
    description: "通过简单可执行的餐盘策略，减少午后疲惫和认知波动。",
  },
];

const themePanels: ThemePanel[] = [
  {
    id: "investment",
    title: "投资主题",
    countLabel: `当前已上线章节：${investmentItems.length}`,
    items: investmentItems,
  },
  {
    id: "technology",
    title: "科技主题",
    subtitle: "先放 3 篇占位预告，后续逐步替换成正式内容。",
    items: technologyItems,
  },
  {
    id: "health",
    title: "健康主题",
    subtitle: "先放 3 篇占位预告，后续会上线完整章节。",
    items: healthItems,
  },
];
---

<Layout>
  <Header />
  <main id="main-content" data-layout="index" class="page-enter app-layout content-grid">
    <section
      class="theme-hero content-grid__full flex flex-col items-center border-b border-border py-10 text-center"
    >
      <p class="theme-eyebrow">Crafting a resilient life through wealth, health, and logic.</p>
      <h1 class="theme-title theme-title--hero">用极简框架，构建长期有效的投资系统</h1>
      <p class="theme-subtitle">
        以都市生活叙事为线索，把资产配置、风险管理与市场常识，拆解成可执行的日常动作。
      </p>

      <div class="theme-switcher" role="tablist" aria-label="内容主题">
        <button
          type="button"
          class="theme-chip is-active"
          data-theme="investment"
          role="tab"
          aria-selected="true"
          aria-controls="theme-panel-investment"
          id="theme-tab-investment"
        >
          <span class="theme-chip__icon theme-chip__icon--investment" aria-hidden="true">
            <svg viewBox="0 0 24 24" focusable="false">
              <circle cx="9" cy="9" r="3.2"></circle>
              <path d="M14.2 15.5h6.3"></path>
              <path d="M14.2 11.8h4.8"></path>
              <path d="M7 14.8h4"></path>
            </svg>
          </span>
          投资
        </button>
        <button
          type="button"
          class="theme-chip"
          data-theme="technology"
          role="tab"
          aria-selected="false"
          aria-controls="theme-panel-technology"
          id="theme-tab-technology"
        >
          <span class="theme-chip__icon theme-chip__icon--technology" aria-hidden="true">
            <svg viewBox="0 0 24 24" focusable="false">
              <rect x="7.2" y="7.2" width="9.6" height="9.6" rx="1.6"></rect>
              <path d="M9.6 9.6h4.8v4.8H9.6z"></path>
              <path d="M5 9.2v1.6M5 13.2v1.6M19 9.2v1.6M19 13.2v1.6"></path>
            </svg>
          </span>
          科技
        </button>
        <button
          type="button"
          class="theme-chip"
          data-theme="health"
          role="tab"
          aria-selected="false"
          aria-controls="theme-panel-health"
          id="theme-tab-health"
        >
          <span class="theme-chip__icon theme-chip__icon--health" aria-hidden="true">
            <svg viewBox="0 0 24 24" focusable="false">
              <path d="M12 6.8v10.4"></path>
              <path d="M6.8 12h10.4"></path>
            </svg>
          </span>
          健康
        </button>
      </div>
    </section>

    {
      themePanels.map(panel => (
        <section
          id={`theme-panel-${panel.id}`}
          class:list={[
            "theme-panel py-10",
            {
              "hidden": panel.id !== "investment",
              "theme-panel--investment": panel.id === "investment",
            },
          ]}
          role="tabpanel"
          aria-labelledby={`theme-tab-${panel.id}`}
        >
          <div
            class:list={[
              "theme-surface",
              { "theme-surface--investment": panel.id === "investment" },
            ]}
          >
            <div class="mb-8 flex flex-wrap items-end justify-between gap-3">
              <h2 class="text-2xl font-semibold tracking-wide">{panel.title}</h2>
              {panel.countLabel && <span class="text-sm text-foreground/60">{panel.countLabel}</span>}
            </div>

            {panel.subtitle && <p class="theme-panel-subtitle">{panel.subtitle}</p>}

            <ul class="theme-topic-list">
              {
                panel.items.map((item, index) => {
                  const gradientId = `${panel.id}-thumbBg-${index}`;
                  const isInvestment = panel.id === "investment";
                  const fallbackStopA = isInvestment ? "#f7f2e7" : "#eef1f5";
                  const fallbackStopB = isInvestment ? "#ece2ce" : "#dbe4ee";
                  const fallbackStrokeA = isInvestment ? "#b79e76" : "#8da1ba";
                  const fallbackStrokeB = isInvestment ? "#7f6540" : "#607d9d";

                  const itemClasses = [
                    "theme-topic-link",
                    { "theme-topic-link--static": !item.href },
                  ];

                  return (
                    <li
                      class="theme-topic-item"
                      data-home-card={isInvestment ? "true" : undefined}
                      hidden={isInvestment && index > 5 ? true : undefined}
                    >
                      {item.href ? (
                        <a
                          href={item.href}
                          class:list={itemClasses}
                          style={`animation-delay: calc(${index} * 70ms);`}
                        >
                          <div class="theme-topic-copy">
                            <h3 class="theme-topic-title theme-topic-title--compact text-foreground">
                              {item.title}
                            </h3>
                            <p class="theme-topic-desc">{item.description}</p>
                          </div>
                          <div class="theme-topic-thumb" aria-hidden="true">
                            {item.coverImage ? (
                              <img src={item.coverImage} alt="" loading="lazy" decoding="async" />
                            ) : (
                              <svg viewBox="0 0 320 220" role="img" aria-label="文章默认配图">
                                <defs>
                                  <linearGradient id={gradientId} x1="0" y1="0" x2="1" y2="1">
                                    <stop offset="0%" stop-color={fallbackStopA}></stop>
                                    <stop offset="100%" stop-color={fallbackStopB}></stop>
                                  </linearGradient>
                                </defs>
                                <rect width="320" height="220" rx="18" fill={`url(#${gradientId})`} />
                                <path d="M46 44v132M46 176h228" stroke={fallbackStrokeA} stroke-width="2" />
                                <path
                                  d="M74 148 106 132 132 138 164 108 198 116 234 84 266 98"
                                  fill="none"
                                  stroke={fallbackStrokeB}
                                  stroke-width="4"
                                  stroke-linecap="round"
                                  stroke-linejoin="round"
                                />
                              </svg>
                            )}
                          </div>
                        </a>
                      ) : (
                        <div class:list={itemClasses}>
                          <div class="theme-topic-copy">
                            <h3 class="theme-topic-title theme-topic-title--compact text-foreground">
                              {item.title}
                            </h3>
                            <p class="theme-topic-desc">{item.description}</p>
                          </div>
                          <div class="theme-topic-thumb" aria-hidden="true">
                            <svg viewBox="0 0 320 220" role="img" aria-label="文章默认配图">
                              <defs>
                                <linearGradient id={gradientId} x1="0" y1="0" x2="1" y2="1">
                                  <stop offset="0%" stop-color={fallbackStopA}></stop>
                                  <stop offset="100%" stop-color={fallbackStopB}></stop>
                                </linearGradient>
                              </defs>
                              <rect width="320" height="220" rx="18" fill={`url(#${gradientId})`} />
                              <path d="M46 44v132M46 176h228" stroke={fallbackStrokeA} stroke-width="2" />
                              <path
                                d="M74 148 106 132 132 138 164 108 198 116 234 84 266 98"
                                fill="none"
                                stroke={fallbackStrokeB}
                                stroke-width="4"
                                stroke-linecap="round"
                                stroke-linejoin="round"
                              />
                            </svg>
                          </div>
                        </div>
                      )}
                    </li>
                  );
                })
              }
            </ul>
            {panel.id === "investment" && <div id="home-posts-sentinel" class="h-4" aria-hidden="true"></div>}
          </div>
        </section>
      ))
    }

    <div class="my-8 text-center">
      <LinkButton href="/posts/">
        文章目录
        <IconArrowRight class="inline-block rtl:-rotate-180" />
      </LinkButton>
    </div>
  </main>
  <Footer />
</Layout>

<script>
  function initIndexPageInteractions() {
    const mainContent = document.querySelector("#main-content");
    const indexLayout = mainContent?.getAttribute("data-layout");
    if (!indexLayout) return;
    if (mainContent instanceof HTMLElement && mainContent.dataset.interactiveReady === "true") return;

    sessionStorage.setItem("backUrl", "/");

    const tabs = Array.from(document.querySelectorAll(".theme-chip"));
    const panels = Array.from(document.querySelectorAll(".theme-panel"));
    if (!tabs.length || !panels.length) return;

    const activate = (theme: string | null | undefined) => {
      if (!theme) return;
      tabs.forEach(tab => {
        const tabTheme = tab.getAttribute("data-theme");
        const isSelected = tabTheme === theme;
        tab.classList.toggle("is-active", isSelected);
        tab.setAttribute("aria-selected", isSelected ? "true" : "false");
      });

      panels.forEach(panel => {
        const shouldShow = panel.id === `theme-panel-${theme}`;
        panel.classList.toggle("hidden", !shouldShow);
      });
    };

    tabs.forEach(tab => {
      tab.addEventListener("click", () => activate(tab.getAttribute("data-theme")));
    });

    const queryTheme = new URLSearchParams(window.location.search).get("theme");
    activate(queryTheme ?? "investment");

    const cards = Array.from(document.querySelectorAll("[data-home-card]"));
    const sentinel = document.querySelector("#home-posts-sentinel");
    if (!cards.length || !sentinel) return;

    const estimateCardHeight = 168;
    const initialCount = Math.max(
      6,
      Math.ceil(((window.innerHeight || 800) * 2) / estimateCardHeight)
    );
    const batchCount = 4;
    let shownCount = 0;

    let observer: IntersectionObserver | null = null;

    const reveal = (count: number) => {
      const nextCount = Math.min(cards.length, shownCount + count);
      for (let i = shownCount; i < nextCount; i++) {
        cards[i]?.removeAttribute("hidden");
      }
      shownCount = nextCount;
      if (shownCount >= cards.length) observer?.disconnect();
    };

    reveal(initialCount);

    observer = new IntersectionObserver(
      entries => {
        if (entries.some(entry => entry.isIntersecting)) {
          reveal(batchCount);
        }
      },
      { rootMargin: "220px 0px" }
    );

    observer.observe(sentinel);
    if (mainContent instanceof HTMLElement) {
      mainContent.dataset.interactiveReady = "true";
    }
  }

  document.addEventListener("astro:page-load", initIndexPageInteractions);
  document.addEventListener("DOMContentLoaded", initIndexPageInteractions);
</script>

